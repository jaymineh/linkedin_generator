# Copy to .env.local for local Next.js dev

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APPLICATIONINSIGHTS_CONNECTION_STRING=

# Clerk (optional). If unset, the app runs without sign-in.
# Get keys from https://dashboard.clerk.com → your application → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Used by Clerk Dashboard / backend integrations — not required for this static frontend alone
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
